{
  "name": "nstc",
  "version": "0.1.0",
  "description": "Rails-like resource scaffolder for NestJS APIs using TypeORM.",
  "type": "module",
  "bin": {
    "nstc": "./dist/bin/nstc.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "AGENTS.md"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run build && node --test dist/test/*.test.js",
    "smoke": "npm run build && node ./dist/bin/nstc.js generate resource post title:string body:text published:boolean --dry-run",
    "prepublishOnly": "npm run lint && npm test"
  },
  "keywords": [
    "nestjs",
    "scaffold",
    "typeorm",
    "cli",
    "generator",
    "nstc"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.21",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.0"
  }
}
